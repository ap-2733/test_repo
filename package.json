{
  "name": "monorepo",
  "private": true,
  "packageManager": "npm@11.17.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "android": "cd ./apps/mobile && react-native run-android",
    "web": "cd ./apps/web && vite"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "prettier": "^3.8.5",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "allowScripts": {
    "esbuild@0.21.5": true
  },
  "dependencies": {
    "@faker-js/faker": "^10.5.0"
  }
}
